{
  "name": "@wrelik/upstash",
  "version": "1.1.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lwhite702/wrelik-kit.git",
    "directory": "packages/upstash"
  },
  "sideEffects": false,
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.mjs",
      "require": "./dist/shared/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/server/index.ts src/client/index.ts src/shared/index.ts --format cjs,esm --dts --clean",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@upstash/ratelimit": ">=2 <3",
    "@upstash/redis": ">=1 <2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@wrelik/eslint-config": "workspace:*",
    "@wrelik/tsconfig": "workspace:*",
    "tsup": "^8.5.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  },
  "wrelik": {
    "runtimes": [
      "server",
      "client",
      "shared"
    ],
    "packageClass": "platform-wrapper"
  }
}
